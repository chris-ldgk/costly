# Local secrets and scripts — copy to .env (gitignored)
# Wrangler dev loads these when no .dev.vars file is present. Do not use .dev.vars.

BETTER_AUTH_SECRET=dev-secret-min-32-characters-long!!
# Optional — omit in development to log magic links to the console instead
# RESEND_API_KEY=

# Drizzle Kit only (not a Worker binding)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/costly-api

# Public vars (CORS_ORIGINS, BETTER_AUTH_URL, ALLOWED_USERS, NODE_ENV, RESEND_FROM_EMAIL)
# are configured in wrangler.jsonc → vars
