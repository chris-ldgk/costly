BETTER_AUTH_SECRET=secret-value

# Worker secrets — copy .dev.vars.example → .dev.vars (Wrangler dev)
# Drizzle Kit only (not a Worker binding) — copy this file → .env
DATABASE_URL=postgres://postgres:postgres@localhost:5432/costly-api

# Public vars (PUBLIC_URL, CORS_ORIGINS, BETTER_AUTH_URL, ALLOWED_USERS, NODE_ENV)
